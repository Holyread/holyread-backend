{
  "name": "holyread-backend",
  "version": "0.0.2",
  "description": "holyread api",
  "main": "app.js",
  "scripts": {
    "start": "node dist/src/app.js",
    "clean": "rimraf \"dist/*\"",
    "lint": "tslint --project ./",
    "lint-fix": "npm run lint -- --fix",
    "tsc": "tsc --project ./",
    "build-files": "copyfiles -u 0 src/views/*.html dist/",
    "build": "npm run tsc",
    "watch": "./node_modules/nodemon/bin/nodemon.js -e ts  --exec \"tsc\"",
    "start-dev": "nodemon dist/src/app.js",
    "build-run": "tsc && npm start",
    "test": "NODE_ENV=test jest"
  },
  "engines": {
    "node": "v20.12.2",
    "npm": "10.6.0"
  },
  "config": {
    "mongodbMemoryServer": {
      "version": "latest",
      "debug": "true"
    }
  },
  "keywords": [],
  "devDependencies": {
    "@types/async": "^3.2.24",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/cron": "^2.4.0",
    "@types/dotenv": "^6.1.1",
    "@types/express": "*",
    "@types/node": "^20.12.7",
    "copyfiles": "^2.4.1",
    "jsonwebtoken": "^9.0.2",
    "nodemon": "^3.1.0",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@types/boom": "^7.3.5",
    "aws-sdk": "^2.1607.0",
    "axios": "^1.6.8",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "cron": "^3.1.7",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "4.19.2",
    "firebase-admin": "^12.1.0",
    "fs": "^0.0.1-security",
    "handlebars": "^4.7.8",
    "mongoose": "^8.3.2",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.13",
    "rimraf": "^5.0.5",
    "socket.io": "^4.7.5",
    "stripe": "^15.4.0",
    "ts-node": "^10.9.2",
    "tslint": "^6.1.3"
  },
  "author": "Holy Reads",
  "bugs": {
    "url": "https://github.com/Holyread/holyread-backend/issues"
  },
  "homepage": "https://holyreads.com"
}
