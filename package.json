{
  "name": "holyread-backend",
  "main": "app.js",
  "author": "Holy Reads",
  "version": "0.0.2",
  "homepage": "https://holyreads.com",
  "description": "holyread api",
  "scripts": {
    "tsc": "tsc --project ./",
    "lint": "tslint --project ./",
    "test": "NODE_ENV=test jest",
    "start": "node dist/src/app.js",
    "clean": "rimraf \"dist/*\"",
    "build": "npm run tsc",
    "watch": "./node_modules/nodemon/bin/nodemon.js -e ts  --exec \"tsc\"",
    "lint-fix": "npm run lint -- --fix",
    "start-dev": "nodemon dist/src/app.js",
    "build-run": "tsc && npm start",
    "build-files": "copyfiles -u 0 src/views/*.html dist/"
  },
  "engines": {
    "npm": "6.0.0",
    "node": "14.17.3"
  },
  "config": {
    "mongodbMemoryServer": {
      "debug": "true",
      "version": "latest"
    }
  },
  "keywords": [],
  "devDependencies": {
    "@types/node": "*",
    "nodemon": "^2.0.6",
    "copyfiles": "^2.4.1",
    "@types/cors": "^2.8.9",
    "@types/cron": "^2.0.0",
    "@types/async": "^3.2.5",
    "@types/dotenv": "^4.0.2",
    "@types/express": "*",
    "@types/compression": "^1.7.0",
    "@types/cookie-parser": "^1.4.2"
  },
  "dependencies": {
    "cron": "^2.1.0",
    "cors": "^2.8.5",
    "axios": "^0.27.2",
    "dotenv": "^8.2.0",
    "rimraf": "^3.0.2",
    "tslint": "^6.1.3",
    "stripe": "^9.6.0",
    "ts-node": "^10.0.0",
    "aws-sdk": "^2.817.0",
    "express": "4.17.1",
    "mongoose": "^5.13.8",
    "node-cron": "^3.0.0",
    "socket.io": "^4.5.1",
    "@hapi/boom": "^9.1.2",
    "handlebars": "^4.7.7",
    "nodemailer": "^6.7.2",
    "@types/boom": "^7.3.0",
    "compression": "^1.7.4",
    "jsonwebtoken": "^8.5.1",
    "cookie-parser": "^1.4.5",
    "firebase-admin": "^11.0.0"
  },
  "bugs": {
    "url": "https://github.com/Holyread/holyread-backend/issues"
  }
}
